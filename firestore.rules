rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Projects: Authenticated users can read. Admins or owners can write.
    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || resource.data.ownerId == request.auth.uid);

      // Tasks (direct access within a project): Authenticated users can read/write.
      match /tasks/{taskId} {
        allow read, write: if isAuthenticated();
      }
      
      // Releases (direct access within a project): Authenticated users can read/write.
      match /releases/{releaseId} {
        allow read, write: if isAuthenticated();
      }
    }

    // Task Collection Group Queries: This is the critical rule for My Tasks & Calendar.
    // It allows a user to perform a query across all tasks, but ONLY if they are
    // specifically querying for tasks assigned to themselves.
    match /{path=**}/tasks/{taskId} {
       allow list: if isAuthenticated() && request.query.where[0][1] == "assignedToId" && request.query.where[0][2] == request.auth.uid;
       allow get: if isAuthenticated() && request.auth.uid == get(/databases/$(database)/documents/$(path)/tasks/$(taskId)).data.assignedToId;
    }
    
    // Users: Can read any profile, but only write to their own. Admins can write to any.
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Company Profile: Readable by all, writable only by admins.
    match /companyProfile/{profileId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}