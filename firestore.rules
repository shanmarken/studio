
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read and write their own user state, which tracks if their account has been seeded with initial data.
    match /userStates/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Users can read, write, create, and delete their own projects and all sub-collections (like tasks).
    match /users/{userId}/{documents=**} {
      allow read, write, delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
