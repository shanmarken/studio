rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/update their own profile. Admins can update any profile.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Rule for the 'tasks' collection group query used in "My Tasks" and Calendar.
    // Any authenticated user can query tasks across all projects.
    match /{path=**}/tasks/{taskId} {
      allow read: if request.auth != null;
    }

    // Projects can be read and written by any authenticated user.
    match /projects/{projectId} {
      allow read, write: if request.auth != null;

      // Tasks can be read, created, updated, and deleted by any authenticated user.
      // Read access is also covered by the collection group query rule above, but this is for direct access.
      match /tasks/{taskId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
