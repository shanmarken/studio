
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is an admin
    function isAdmin(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role == 'admin';
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Any authenticated user can read their own user document.
      // Admins can read any user document.
      allow read: if request.auth.uid != null && (request.auth.uid == userId || isAdmin(request.auth.uid));
      
      // An authenticated user can update their own document (e.g., displayName).
      // An admin can update any user document.
      allow update: if request.auth.uid != null && (request.auth.uid == userId || isAdmin(request.auth.uid));

      // Only admins can create or delete users through this rule.
      // (Creation is typically handled by Firebase Auth triggers or signup logic)
      allow create, delete: if request.auth.uid != null && isAdmin(request.auth.uid);
    }

    // Rules for 'projects' and their subcollections
    match /projects/{projectId}/{document=**} {
      // Allow any authenticated user to read and write to projects and their sub-collections (tasks, etc.)
      allow read, write: if request.auth.uid != null;
    }

    // Allow collection group queries for 'tasks' for any authenticated user
    match /{path=**}/tasks/{taskId} {
      allow read: if request.auth.uid != null;
    }
  }
}
