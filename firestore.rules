
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isRole(role) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // AUTH: Users can only see their own profile, but any authenticated user can create one.
    // Admins can see any profile.
    match /users/{userId} {
      allow read, write: if isUser(userId) || isRole('admin');
    }

    // COMPANY PROFILE: Any authenticated user can read it, only admins can write.
    match /companyProfile/{docId} {
      allow read: if isSignedIn();
      allow write: if isRole('admin');
    }

    // PROJECTS: Any authenticated user can read projects and their subcollections (releases/tasks).
    // This is required for developers to see project names and task details.
    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow write: if isRole('admin');

      // RELEASES: Any authenticated user can read releases.
      match /releases/{releaseId} {
        allow read: if isSignedIn();
        allow create, delete: if isRole('admin') || isRole('management');
      }

      // TASKS:
      // Allow creation by any authenticated user.
      // Allow updates/deletes by admins or the assigned user.
      match /tasks/{taskId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && (isRole('admin') || request.auth.uid == resource.data.assignedToId);
      }
    }

    // COLLECTION GROUP:
    // Allow a user to query the 'tasks' collection group across all projects
    // ONLY if the query is filtering for tasks assigned to that specific user.
    // This is what powers the "My Tasks" and "Calendar" views securely.
    match /{path=**}/tasks/{taskId} {
      allow list: if isSignedIn() && request.query.where.size() > 0 && request.query.where[0].field == 'assignedToId' && request.query.where[0].value == request.auth.uid;
      allow get: if isSignedIn() && get(/databases/$(database)/documents/$(path)/tasks/$(taskId)).data.assignedToId == request.auth.uid;
    }
  }
}
