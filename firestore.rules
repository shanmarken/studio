rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Allow users to read projects and the company profile, but only write if they are an admin or owner.
    match /projects/{projectId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || request.auth.uid == resource.data.ownerId;
      
      // Releases and other sub-collections can be read by any authenticated user, but only written by admins.
      match /releases/{releaseId} {
         allow read, write: if request.auth != null;
      }
    }
    
    match /companyProfile/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users can read/write their own document. Admins can list all users.
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
      allow list: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // This rule allows a user to query the 'tasks' collection group.
    // It is the key fix for the My Tasks and Calendar pages.
    // A user can get or list tasks if the task's assignedToId matches their own user ID.
    match /{path=**}/tasks/{taskId} {
      allow read, write: if request.auth != null && (request.auth.uid == resource.data.assignedToId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
  }
}
