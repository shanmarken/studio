
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the requesting user is the owner of a document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Users can only read/update their own user document
    match /users/{userId} {
      allow read, update: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn();
    }

    // Allow authenticated users to read company profile
    match /companyProfile/{docId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Allow read/write access to projects for any authenticated user
    // In a production app, you would likely restrict write access to project members/owners
    match /projects/{projectId} {
      allow read, write: if isSignedIn();

      // For tasks as a subcollection of projects
      match /tasks/{taskId} {
        allow read, write: if isSignedIn();
      }
      
      // For releases as a subcollection of projects
      match /releases/{releaseId} {
        allow read, write: if isSignedIn();
      }
    }
    
    // This rule is required for the cross-project "My Tasks" and "Calendar" queries.
    // It allows a user to read from any document in the "tasks" collection group
    // IF their user ID matches the 'assignedToId' field on that task document.
    match /{path=**}/tasks/{taskId} {
      allow read: if isSignedIn() && resource.data.assignedToId == request.auth.uid;
    }
  }
}
