rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is an admin
    function isAdmin(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role == 'admin';
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Allow users to read their own user document
      // Allow admins to read any user document
      allow read: if request.auth.uid == userId || isAdmin(request.auth.uid);
      
      // Allow users to update their own document
      allow update: if request.auth.uid == userId;

      // Allow any authenticated user to create their own user document (on signup)
      allow create: if request.auth.uid == userId;

      // Rules for the 'projects' subcollection within each user document
      match /projects/{projectId} {
        // Allow users to do anything with their own projects
        // Allow admins to read any project
        allow read: if request.auth.uid == userId || isAdmin(request.auth.uid);
        allow create, update, delete: if request.auth.uid == userId;

        // Rules for the 'tasks' subcollection within each project
        match /tasks/{taskId} {
            // Allow users to do anything with tasks in their own projects
            // Allow admins to read any task
            allow read: if request.auth.uid == userId || isAdmin(request.auth.uid);
            allow create, update, delete: if request.auth.uid == userId;
        }
      }
    }

    // Rules for collection group queries
    match /{path=**}/tasks/{taskId} {
        // Allow reading a task if you are the one it's assigned to
        allow read: if get(path.join(["/"])).data.assignedTo == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.displayName;
    }
  }
}
