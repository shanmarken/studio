
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow authenticated users to read projects and tasks
    match /projects/{projectId}/{document=**} {
      allow read: if request.auth != null;
    }

    // Allow authenticated users to create, update, and delete projects and tasks
    match /projects/{projectId} {
      allow write: if request.auth != null;

      match /tasks/{taskId} {
        allow write: if request.auth != null;
      }
    }
    
    // Allow reading user data for all authenticated users
    match /users/{userId} {
      allow read: if request.auth != null;
      // Allow users to update their own data
      // And allow admins to update any user's data (e.g. for changing roles)
      allow write: if request.auth.uid == userId 
                   || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
