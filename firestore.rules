
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read the list of users to assign tasks, but can only write to their own user document.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // Users can only read/write their own projects and the tasks within them.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth.uid == userId;
    }
  }
}
