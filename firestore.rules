rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is an admin
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users can read their own doc, admins can read any
    match /users/{userId} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid == userId || isAdmin();
    }
    
    // Any authenticated user can read the company profile, only admins can write
    match /companyProfile/{docId} {
      allow read: if request.auth.uid != null;
      allow write: if isAdmin();
    }
    
    // Rules for projects and their subcollections
    match /projects/{projectId} {
      // Any authenticated user can read project details
      allow read: if request.auth.uid != null;
      // Any authenticated user can create a project
      allow create: if request.auth.uid != null;
      // Only admins can update or delete a project
      allow update, delete: if isAdmin();

      // Rules for releases subcollection
      match /releases/{releaseId} {
        // Any authenticated user can read releases
        allow read: if request.auth.uid != null;
        // Any authenticated user can create, update, or delete releases
        allow write: if request.auth.uid != null;
      }
      
      // Rules for tasks subcollection within a project
      match /tasks/{taskId} {
        // Any authenticated user can read a task
        allow read: if request.auth.uid != null;
        // Any authenticated user can create a task
        allow create: if request.auth.uid != null;
        // Users can update/delete a task if they are the assignee or an admin
        allow update, delete: if request.auth.uid == resource.data.assignedToId || isAdmin();
      }
    }
    
    // This rule enables the collectionGroup query for 'tasks' used in MyTasks and Calendar pages.
    // It allows a user to read any task document across all projects ONLY IF it is assigned to them.
    match /{path=**}/tasks/{taskId} {
      allow read: if request.auth.uid == resource.data.assignedToId;
    }
  }
}
