
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Any authenticated user can read user profiles (for assignees, etc.)
      allow read: if isAuth(); 
      // A user can update their own profile, or an admin can update any profile
      allow write: if request.auth.uid == userId || isAdmin();

      // Rules for the 'projects' subcollection
      match /projects/{projectId} {
        // Any authenticated user can view any project
        allow read: if isAuth();
        // Only the project owner or an admin can create, update, or delete a project
        allow write: if request.auth.uid == userId || isAdmin();
      }
    }

    // Allow admins to list all users
    match /users {
      allow list: if isAdmin();
    }
    
    // Rules for 'tasks' collection group
    // This allows the "My Tasks" page to work correctly and securely for all users.
    match /{path=**}/tasks/{taskId} {
       allow read: if isAuth() && (resource.data.assignedToId == request.auth.uid || isAdmin());
       // Write rules are handled by the /users/{userId}/projects/{projectId} path
    }
  }
}
