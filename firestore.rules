rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read;
      allow create, update, delete: if request.auth.uid == userId;
    }

    match /projects/{projectId} {
      allow read, create, update, delete: if request.auth != null;

      match /tasks/{taskId} {
        allow read, create, update, delete: if request.auth != null;
      }
    }
  }
}
