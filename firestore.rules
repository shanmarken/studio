
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read access to any document if the user is authenticated.
    match /{document=**} {
      allow read: if request.auth != null;
    }

    // Allow authenticated users to write to projects.
    match /projects/{projectId} {
      allow write: if request.auth != null;
    }

    // Allow authenticated users to write to tasks within a project.
    match /projects/{projectId}/tasks/{taskId} {
      allow write: if request.auth != null;
    }

    // Allow authenticated users to write to releases within a project.
    match /projects/{projectId}/releases/{releaseId} {
        allow write: if request.auth != null;
    }

    // Allow a user to create and update their own user document.
    match /users/{userId} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
