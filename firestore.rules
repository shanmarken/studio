rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to manage their own user document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow authenticated users to read all projects, tasks, and releases
    match /projects/{projectId}/{document=**} {
      allow read: if request.auth != null;
    }

    // Allow authenticated users to write to projects and subcollections
    match /projects/{projectId} {
     allow write: if request.auth != null;
    }
    
    match /projects/{projectId}/tasks/{taskId} {
        allow write: if request.auth != null;
    }
    
    match /projects/{projectId}/releases/{releaseId} {
        allow write: if request.auth != null;
    }
  }
}
